library(httr)
library(jsonlite)
library(base64enc)
AUTH_URL <- "https://account.groupcls.com/auth/realms/cls/protocol/openid-connect/token"
API_URL  <- "https://api.groupcls.com/telemetry/api/v1"
USERNAME <- Sys.getenv("kineis_user")
PASSWORD <- Sys.getenv("kineis_pass")
auth_resp <- POST(
AUTH_URL,
add_headers("Content-Type" = "application/x-www-form-urlencoded"),
body = list(
grant_type = "password",
client_id  = "api-telemetry",
username   = USERNAME,
password   = PASSWORD
),
encode = "form"
)
stop_for_status(auth_resp)
access_token <- content(auth_resp)$access_token
cat("Token retrieved successfully\n\n")
decode_jwt <- function(token) {
parts <- strsplit(token, "\\.")[[1]]
payload <- rawToChar(base64decode(parts[2]))
fromJSON(payload)
}
jwt_payload <- decode_jwt(access_token)
cat("Customer ID from token:", jwt_payload$customerId, "\n")
cat("Roles:\n")
print(jwt_payload$resource_access$`api-telemetry`$roles)
cat("\n")
device_url <- paste0(API_URL, "/retrieve-device-list")
device_resp <- POST(
device_url,
add_headers(
"accept" = "application/json",
"Authorization" = paste("Bearer", access_token),
"Content-Type" = "application/json"
),
body = charToRaw("{\n}"),
encode = "raw",
verbose()
)
cat("\nStatus Code:", status_code(device_resp), "\n")
cat("Response Body:\n")
cat(content(device_resp, "text", encoding = "UTF-8"), "\n")
access_token
jwt_payload
