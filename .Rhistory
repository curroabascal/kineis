library(terra)
# 1️⃣ Cargar WMS (elige el subdataset correcto)
r <- rast("WMS:https://idecan1.grafcan.es/ServicioWMS/Topobatimetrico?SERVICE=WMS&VERSION=1.1.1&REQUEST=GetMap&LAYERS=TOPOBAT&SRS=EPSG:32628")
crs(r)
# Tenerife aprox
ext_ll <- ext(-16.9, -16.0, 28.0, 28.6)
# convertir bbox a SpatVector
v_ll <- as.polygons(ext_ll, crs="EPSG:4326")
# reproyectar a UTM
v_utm <- project(v_ll, "EPSG:32628")
# extraer nueva extensión
ext_utm <- ext(v_utm)
r_crop <- crop(r, ext_utm)
ext(r)
