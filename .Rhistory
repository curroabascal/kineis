library(sf)
library(httr)
library(jsonlite)
# URL base de la capa (sin el /8 final)
base_url <- "https://ags.oag-fundacion.org/arcgis/rest/services/Batimetrias/Batimetrias/MapServer/8"
# Función para descargar TODOS los features (paginando por MaxRecordCount=1000)
download_isobatas <- function(url) {
# Primero, obtener total de features
count_url <- paste0(url, "/query?where=1=1&outFields=*&returnCountOnly=true&f=json")
total <- fromJSON(count_url)$count
cat("Total de isobatas:", total, "\n")
# Descargar por lotes de 1000
features_list <- list()
for(i in seq(1, total, 1000)) {
query_url <- paste0(url, "/query?",
"where=1=1&",
"outFields=BATIMETRIA,AÑO,FUENTE,OBJECTID&",
"f=json&",
"returnGeometry=true&",
"resultOffset=", i-1, "&",
"resultRecordCount=1000")
cat("Descargando lote", i, "de", total, "\n")
response <- GET(query_url)
data <- fromJSON(content(response, "text"))
if(length(data$features) > 0) {
features_list[[length(features_list)+1]] <- data$features
}
}
# Combinar todo en un sf object
all_features <- do.call(rbind, lapply(features_list, function(x)
st_as_sf(x, sf_column_name = "geometry") %>%
st_set_crs(3857) %>%  # Web Mercator (EPSG:3857)
mutate(BATIMETRIA = sapply(features, function(f) f$attributes$BATIMETRIA),
AÑO = sapply(features, function(f) f$attributes$AÑO),
FUENTE = sapply(features, function(f) f$attributes$FUENTE))
))
return(all_features)
}
# Descargar
isobatas_canarias <- download_isobatas(base_url)
# Descargar
isobatas_canarias <- download_isobatas(base_url)
