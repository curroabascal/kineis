kineis_pass <- readline("CLS password: ")
Sys.setenv(kineis_user = kineis_user, kineis_pass = kineis_pass)
opcion2 <- readline("Do you want to store the credentials? (y/n):")
if (opcion2 == "y") {
writeLines(paste(kineis_user, kineis_pass, sep = "\n"),
con = kineiscredentialsfile)
}
}
else stop("No credentials to access CLS environmental service",
call. = F)
}
