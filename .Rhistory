library(sf)
library(dplyr)
# Función que convierte correctamente ESRI JSON → sf
esri_to_sf <- function(features) {
# Extraer atributos y geometrías
attrs <- lapply(features, function(f) as.data.frame(f$attributes))
attrs_df <- do.call(rbind, attrs)
# Convertir geometrías ESRI a WKT válido
geoms_esri <- lapply(features, function(f) {
if(is.null(f$geometry)) return(NA_character_)
sf::st_as_sfc(sf::rawToChar(jsonlite::base64enc(f$geometry)), crs = 3857)
})
# Crear sf object
st_sf(attrs_df, geometry = do.call(c, geoms_geoms_esri), crs = 3857)
}
# CORREGIDO: Combinar tus 5 lotes
all_features <- do.call(rbind, lapply(features_list, esri_to_sf))
