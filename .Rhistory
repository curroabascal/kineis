get_device_list <- function() {
access_token <- check_credentials()
device_url <- "https://api.groupcls.com/telemetry/api/v1/retrieve-device-list"
device_resp <- POST(
device_url,
add_headers(
Authorization = paste("Bearer", access_token),
Accept = "application/json",
"Content-Type" = "application/json"
),
body = "{\n}",   # EXACT equivalent of bash
encode = "raw"   # ← CRITICAL
)
cat("Status:", status_code(device_resp), "\n")
cat(content(device_resp, "text", encoding = "UTF-8"), "\n")
return(device_resp)
}
