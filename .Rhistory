get_device_list <- function() {
cat("=== Getting Device List ===\n")
access_token <- check_credentials()
API_TELEMETRY_URL <- "https://api.groupcls.com/telemetry/api/v1"
device_url <- paste0(API_TELEMETRY_URL, "/retrieve-device-list")
# Cuerpo mínimo con estructura de DeviceCriteria (prueba variante)
device_payload <- list(
# Podrías probar dejarlo vacío pero estructurado
deviceCriteria = list()
)
device_resp <- POST(
device_url,
add_headers(
Authorization = paste("Bearer", access_token),
Accept = "application/json",
"Content-Type" = "application/json"
),
body = device_payload,
encode = "json"
)
cat("Device list status:", status_code(device_resp), "\n")
cat("Server response:\n")
cat(content(device_resp, "text", encoding = "UTF-8"), "\n")
if (status_code(device_resp) != 200) {
stop("Error del servidor en /retrieve-device-list")
}
devices <- fromJSON(content(device_resp, "text", encoding = "UTF-8"))
return(devices[[1]])
}
